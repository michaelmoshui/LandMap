# =====================================================================
# LandMap environment configuration
# ---------------------------------------------------------------------
# Copy is OPTIONAL. docker-compose.yml ships with sane defaults, so the
# stack runs with zero config. Create a real `.env` only when you want
# to override defaults (e.g. production secrets or a public domain).
#
#   cp .env.example .env      (macOS/Linux)
#   Copy-Item .env.example .env   (Windows PowerShell)
# =====================================================================

# ---- Database (PostGIS) ---------------------------------------------
POSTGRES_USER=landmap
POSTGRES_PASSWORD=landmap
POSTGRES_DB=landmap
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Backend (FastAPI) ----------------------------------------------
# CORS origins allowed to call the API (comma-separated).
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:8080
LOG_LEVEL=info

# ---- Frontend (Vite build-time) -------------------------------------
# Base URL the browser uses to reach the API. Default routes through the
# Caddy proxy at /api, so it works both locally and over the internet.
VITE_API_BASE_URL=/api

# ---- Proxy (Caddy) --------------------------------------------------
# For local use keep ":80". To serve over the internet with automatic
# HTTPS, set this to your domain, e.g. DOMAIN=landmap.example.com
DOMAIN=:80
